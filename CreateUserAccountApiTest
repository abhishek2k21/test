	public static boolean isUsedDoc(String Doctype) {
		String docValue;
		boolean isUsed = true;
		try {
			docValue = GetDoctype(Doctype);
			Class.forName("com.mysql.jdbc.Driver");
			Connection con = DriverManager.getConnection("jdbc:mysql://10.0.100.59:3310/kyc", "bankuser", "bankpass");
			Statement stmt = con.createStatement();
			ResultSet rs = stmt.executeQuery("select cust_id from kyc_user_doc where doc_value='" + docValue + "'");
			if (rs.next() == false) {
				isUsed = false;
			} else {
				isUsed = true;
			}
			con.close();
		} catch (IOException | SQLException | ClassNotFoundException e) {
			e.printStackTrace();
		}
		return isUsed;
	}
	
	public JsonNode checkStatus() {
		BankHttpRequestHeaders requestHeaders = new BankHttpRequestHeaders();		
		requestHeaders.setNewHeader(GlobalConstants.USER_TOKEN,ssoToken);	
		BankHttpRequest request = new BankHttpRequest(env.getProperty(GlobalConstants.FIN_PRODUCT_URL), HttpMethod.GET, requestHeaders, null);
		JsonNode result = getCommonReponseClient.getReponseMessagePS(request);
		return result;	
	}
	
	public  String GetProcessId(String custId) throws IOException  {
		String target = new String(System.getenv("HOME") + "/getProcessId.sh");
		ProcessBuilder pb = new ProcessBuilder("/bin/bash", target,custId);
		Process proc = pb.start();
		BufferedReader read = new BufferedReader(new InputStreamReader(proc.getInputStream()));
		return read.readLine();
	}
	public static String GetDoctype(String docValue) throws IOException {
		String target = new String(System.getenv("HOME") + "/doctype.sh");
		ProcessBuilder pb = new ProcessBuilder("/bin/bash", target, docValue);
		Process proc = pb.start();
		BufferedReader read = new BufferedReader(new InputStreamReader(proc.getInputStream()));
		return read.readLine();
	}
	private JsonNode resumeFinProduct(String isaProcessId,String productType) {
		BankHttpRequestHeaders requestHeaders = new BankHttpRequestHeaders();
		requestHeaders.setNewHeader(GlobalConstants.USER_TOKEN, ssoToken);
		requestHeaders.setNewHeader(GlobalConstants.CONTENT_TYPE, GlobalConstants.APPLICATION_JSON);
		MultiValueMap<String, Object> requestBody = new LinkedMultiValueMap<String, Object>();
		List<String> processIdArray=new ArrayList<>();
		processIdArray.add(isaProcessId);
		requestBody.add(GlobalConstants.CHANNEL, GlobalConstants.B2C_ANDROID);
		requestBody.add(GlobalConstants.PRODUCT_ENUM, productType);
		requestBody.add(GlobalConstants.PROCESS_IDS,processIdArray);		
		BankHttpRequestBody body = new BankHttpRequestBody(requestBody);
		BankHttpRequest request = new BankHttpRequest(env.getProperty(GlobalConstants.FIN_RESUME_URL), HttpMethod.POST,requestHeaders, body);
		JsonNode result = resumeClient.processResumeFinProduct(request);
		return result;			
	}
	
