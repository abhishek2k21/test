        BankHttpRequest request = new BankHttpRequest(url, HttpMethod.POST, headers, body);
        RequestEntity<String> entity = new RequestEntity<String>(sql, request.getRequestHeaders().getRequestHeaders(), request.getMethod(), URI.create(request.getUrl()));
        Reporter.log("database request : " + clientUtils.logRequestEntityObject(entity));
        System.out.println("Query Entity String : " + entity.toString());
        //System.out.println("Query Body :: " + );
        CurlLogger.generateCurl(entity, true);
        ResponseEntity<JsonNode> entityResponse = null;
        JsonNode result = null;
        try {
            boolean exe = true;
            int count = 1;
            while (exe && count < 5) {
                try {
                    MappingJackson2HttpMessageConverter jsonHttpMessageConverter = new MappingJackson2HttpMessageConverter();
                    RestTemplate restTemplate = new RestTemplate();
                    HttpComponentsClientHttpRequestFactory factory = new HttpComponentsClientHttpRequestFactory();
                    factory.setConnectionRequestTimeout(60000);
                    factory.setConnectTimeout(60000);
                    restTemplate.setRequestFactory(factory);
                    restTemplate.getMessageConverters().add(jsonHttpMessageConverter);
                    entityResponse = restTemplate.exchange(entity, JsonNode.class);
                    exe = false;
                    Reporter.log("Http response status code : " + entityResponse.getStatusCode(), true);
                    Reporter.log("Http response body : " + entityResponse.getBody(), true);
                    logger.info("Http response body : " + entityResponse.getBody());
                    result = mapper.readValue(entityResponse.getBody().toString(), JsonNode.class);
                } catch (ResourceAccessException exeception) {
                    exe = true;
                    count++;
                }
            }
            return new ResponseEntity<JsonNode>(result, entityResponse.getStatusCode());
        } catch (HttpClientErrorException | HttpServerErrorException e) {
            Reporter.log("http response: " + e.getMessage());
            Reporter.log("database response : " + e.getResponseBodyAsString());
            logger.info("database response : " + e.getResponseBodyAsString());
            JsonNode neftResponse = mapper.readValue(e.getResponseBodyAsString().toString(), JsonNode.class);
            return new ResponseEntity<JsonNode>(neftResponse, e.getStatusCode());
        } catch (Exception e) {
            Reporter.log("Exception caught: " + e.getMessage());
            System.out.println(e.getMessage());
            logger.info(e.getMessage());
            e.printStackTrace();
            throw e;
        }

    }

