        BankHttpRequestHeaders headers = new BankHttpRequestHeaders();
        headers.setNewHeader(GlobalConstants.ACCEPT, GlobalConstants.APPLICATION_JSON);
        headers.setNewHeader(GlobalConstants.CONTENT_TYPE, GlobalConstants.APPLICATION_JSON);


