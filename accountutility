	public String GetProcessId(String custId) throws IOException {
		String target = new String(System.getenv("HOME") + "/getProcessId.sh");
		ProcessBuilder pb = new ProcessBuilder("/bin/bash", target, custId);
		Process proc = pb.start();
		BufferedReader read = new BufferedReader(new InputStreamReader(proc.getInputStream()));
		return read.readLine();
	}

	public static String GetDoctype(String docValue) throws IOException {
		String target = new String(System.getenv("HOME") + "/doctype.sh");
		ProcessBuilder pb = new ProcessBuilder("/bin/bash", target, docValue);
		Process proc = pb.start();
		BufferedReader read = new BufferedReader(new InputStreamReader(proc.getInputStream()));
		return read.readLine();
	}

	public void deleteFromKYC(String doctype) {
		String docValue;
		try {
			docValue = GetDoctype(doctype);
			String deleteQuery = "DELETE FROM kyc_user_doc where id=?;";
			Class.forName("com.mysql.jdbc.Driver");
			Connection con = DriverManager.getConnection("jdbc:mysql://10.0.100.59:3310/kyc", "bank_user", "bank_pass");
			Statement stmt = con.createStatement();
			PreparedStatement ps = con.prepareStatement(deleteQuery);
			int id;
			ResultSet rs = stmt.executeQuery("select id from kyc_user_doc where doc_value='" + docValue + "'");
			if (rs.next() == false) {
				Reporter.log("No Data Found for DocValue: " + doctype);
			} else {
				id = rs.getInt(1);
				ps.setInt(1, id);
				ps.executeUpdate();
			}
			con.close();
		} catch (IOException | SQLException | ClassNotFoundException e) {
			e.printStackTrace();
		}
	}

	@SuppressWarnings("rawtypes")
	public Map<String, List<String>> readDataFromXls(int column, String value) {
		String csvFile = env.getProperty(GlobalConstants.TEST_EXCEL_FILE);
		Map<String, List<String>> inputMap = new HashMap<String, List<String>>();
		HSSFWorkbook wb;
		try {
			wb = new HSSFWorkbook(new FileInputStream(csvFile));
			HSSFSheet sheet = wb.getSheetAt(0);
			HSSFRow row;
			HSSFCell cell;
			Iterator rows = sheet.rowIterator();
			while (rows.hasNext()) {
				row = (HSSFRow) rows.next();
				String check = row.getCell(column).getStringCellValue();
				if (check.equals(value)) {
					List<String> values = new ArrayList<String>();

					Iterator cellItr = row.cellIterator();
					while (cellItr.hasNext()) {
						cell = (HSSFCell) cellItr.next();
						cell.setCellType(Cell.CELL_TYPE_STRING);
						values.add(readCellValue(cell));
					}
					inputMap.put(row.getCell(0).getStringCellValue(), values);
				}
			}
		} catch (FileNotFoundException e) {
			e.printStackTrace();
		} catch (IOException e) {
			e.printStackTrace();
		}
		return inputMap;
	}

	private String readCellValue(Cell cell) {
		switch (cell.getCellType()) {
		case Cell.CELL_TYPE_BLANK:
			return "(blank)";
		case Cell.CELL_TYPE_BOOLEAN:
			return String.valueOf(cell.getBooleanCellValue());
		case Cell.CELL_TYPE_ERROR:
			return String.valueOf(cell.getErrorCellValue());
		case Cell.CELL_TYPE_NUMERIC:
			return String.valueOf(cell.getNumericCellValue());
		case Cell.CELL_TYPE_STRING:
			return cell.getStringCellValue();
		default:
			return "Unknown type!";
		}
	}

	public void writeDataInXls(String match, String value, int column) {
		String inputFile = env.getProperty(GlobalConstants.TEST_EXCEL_FILE);
		HSSFWorkbook wb;
		try {
			wb = new HSSFWorkbook(new FileInputStream(inputFile));
			HSSFSheet sheet = wb.getSheetAt(0);
			int rowIndex = findRow(sheet, match);
			sheet.getRow(rowIndex).getCell(column).setCellValue(value);
			FileOutputStream fout = new FileOutputStream(inputFile);
			wb.write(fout);
			fout.close();
		} catch (FileNotFoundException e) {
			e.printStackTrace();
		} catch (IOException e) {
			e.printStackTrace();
		}
	}

	private static int findRow(HSSFSheet sheet, String cellContent) {
		for (Row row : sheet) {
			for (Cell cell : row) {
				if (cell.getCellType() == Cell.CELL_TYPE_STRING) {
					if (cell.getRichStringCellValue().getString().trim().equals(cellContent)) {
						return row.getRowNum();
					}
				}
			}
		}
		return 0;
	}

	private JsonNode resumeFinProduct(String isaProcessId, String productType) {
		BankHttpRequestHeaders requestHeaders = new BankHttpRequestHeaders();
		requestHeaders.setNewHeader(GlobalConstants.USER_TOKEN, ssoToken);
		requestHeaders.setNewHeader(GlobalConstants.CONTENT_TYPE, GlobalConstants.APPLICATION_JSON);
		MultiValueMap<String, Object> requestBody = new LinkedMultiValueMap<String, Object>();
		List<String> processIdArray = new ArrayList<>();
		processIdArray.add(isaProcessId);
		requestBody.add(GlobalConstants.CHANNEL, GlobalConstants.B2C_ANDROID);
		requestBody.add(GlobalConstants.PRODUCT_ENUM, productType);
		requestBody.add(GlobalConstants.PROCESS_IDS, processIdArray);
		BankHttpRequestBody body = new BankHttpRequestBody(requestBody);
		BankHttpRequest request = new BankHttpRequest(env.getProperty(GlobalConstants.FIN_RESUME_URL), HttpMethod.POST,
				requestHeaders, body);
		JsonNode result = resumeClient.processResumeFinProduct(request);
		return result;
	}

