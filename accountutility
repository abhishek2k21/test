	}

	private BankHttpRequest getCreateAccountPreSteps(Map.Entry<String, List<String>> input_data, boolean isNominee,
			boolean isVDC) {
		Map<String, String> responseMap = accountSteps.initialCreateAccountSteps(input_data.getKey());
		BankHttpRequestHeaders requestHeaders = new BankHttpRequestHeaders();
		requestHeaders.setNewHeader(GlobalConstants.CACHE_CONTROL, GlobalConstants.NO_CACHE);
		requestHeaders.setNewHeader(GlobalConstants.CONTENT_TYPE, GlobalConstants.APPLICATION_JSON);
		ssoToken = responseMap.get(GlobalConstants.SSO_TOKEN);
		custId = responseMap.get(GlobalConstants.RESOURCE_OWNER_ID);
		requestHeaders.setNewHeader(GlobalConstants.USER_TOKEN, ssoToken);
		requestHeaders.setNewHeader(GlobalConstants.RESOURCE_OWNER_ID, custId);
		MultiValueMap<String, Object> bodyParams = new LinkedMultiValueMap<String, Object>();
		List<String> productList = new ArrayList<String>();
		productList.add(GlobalConstants.ISA);
		productList.add(GlobalConstants.VDC);
		bodyParams.add(GlobalConstants.PRODUCTS, productList);
		if (isNominee) {
			testUtil.fillNomineeDetailsInMap(bodyParams);
		}
		bodyParams.add(GlobalConstants.CHANNEL, GlobalConstants.B2C_ANDROID);
		BankHttpRequestBody requestBody = new BankHttpRequestBody(bodyParams);
		BankHttpRequest httpRequest = new BankHttpRequest(env.getProperty(GlobalConstants.FIN_PRODUCT_URL),
				HttpMethod.POST, requestHeaders, requestBody);
		return httpRequest;
	}

