	public String createISA(String AccountType) throws Exception {
		input_data = readDataFromXls(1, AccountType);
		Map.Entry<String, List<String>> entry = input_data.entrySet().iterator().next();
		addhaar = entry.getValue().get(4);
		pan = entry.getValue().get(8);
		if (isUsedDoc(addhaar) || isUsedDoc(pan)) {
			Reporter.log("Account Creation Failed because KYC data Provided is Already Used.");
			Assert.fail("KYC data Provided for mobile no :" + entry.getKey()
					+ " is Already Used!!!.Please try with another KYC Data");

		} else {
			BankHttpRequest request = getCreateAccountPreSteps(entry, false, true);
			String createRequestResp = accountSteps.accountCreationTestCases(0, request, entry);
			int retry = 3;
			String processIds = GetProcessId(custId).toString();
			String isaprocessId = processIds.substring(50, 86);
			String vdcprocessId = processIds.substring(87, 123);
			while (retry > 0 && !(createRequestResp.equalsIgnoreCase(GlobalConstants.ISSUED))) {
				resumeFinProduct(isaprocessId, "isa");
				resumeFinProduct(vdcprocessId, "vdc");
				Thread.sleep(10000);
				createRequestResp = checkStatus().get(GlobalConstants.ISA.toLowerCase()).get(GlobalConstants.STATUS)
						.asText();
				System.err.println("Fin Product Status " + createRequestResp);
				retry--;
				isaprocessId = processIds.substring(87, 123).toString();
				isaprocessId = processIds.substring(50, 86).toString();
			}
			Reporter.log("Account Details");
			Reporter.log("Mobile No:" + entry.getKey() + "\tCustID: " + custId + "\tSSO-Token: " + ssoToken);
			writeDataInXls(entry.getKey(), Long.toString(Long.parseLong(entry.getKey()) + 1), 0);
			Assert.assertEquals(createRequestResp, GlobalConstants.ISSUED);
		}
		return entry.getKey();
	}

